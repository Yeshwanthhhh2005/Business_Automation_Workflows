        "jsCode": "// HR Input Normalization - universal contract from WF-0 (standalone fallback)\nconst t = $('Execute Workflow Trigger').item.json || {};\nconst payloadRaw = t.payload != null ? t.payload : { task: t.task || t.query || 'HR review', details: t };\nconst payload = (typeof payloadRaw === 'string') ? payloadRaw : JSON.stringify(payloadRaw);\nreturn [{ json: {\n  request_id: t.request_id || ('HR_' + Date.now()),\n  workflow_source: t.workflow_source || 'WF-0',\n  mode: t.mode || 'simulation',\n  risk_level: t.risk_level || 'low',\n  confidence: (typeof t.confidence === 'number') ? t.confidence : 0.9,\n  founder_available: t.founder_available || false,\n  timestamp: new Date().toISOString(),\n  payload: payload,\n  payload_obj: (typeof payloadRaw === 'object') ? payloadRaw : { task: payload }\n}}];"
      },
