    {
      "parameters": {
        "jsCode": "// HR Final Decision -> universal output contract\nconst cfg = $('Workflow Configuration').item.json;\nconst inp = $('Input Normalization').item.json;\nconst get = (name) => { try { return $(name).item.json || {}; } catch (e) { return {}; } };\nconst chro = get('CHRO Orchestrator Agent');\nconst talent = get('Talent Insights Agent');\nconst culture = get('Culture Engagement Agent');\nconst policy = get('Policy Enforcement Agent');\nconst hiring = get('Hiring Ops Agent');\nconst perf = get('Performance Review Agent');\nconst rank = { low: 1, medium: 2, high: 3 };\nconst risks = [inp.risk_level, chro.risk_level, policy.severity, culture.burnout_risk].filter(Boolean);\nlet risk_level = 'low';\nfor (const r of risks) { if ((rank[r] || 0) > (rank[risk_level] || 0)) risk_level = r; }\nconst policy_block = policy.policy_violation === true && policy.severity === 'high';\nconst decision_status = policy_block ? 'rejected' : (risk_level === 'high' ? 'waiting' : 'approved');\nconst needs_crea = ['medium','high'].includes(risk_level) || policy.policy_violation === true;\nconst founder_needed = risk_level === 'high' || (hiring && (hiring.ranking || []).length > 0);\nconst reason = policy_block ? ('Blocked by HR policy: ' + (policy.violations || []).join('; ')) : ('CHRO: ' + (chro.summary || 'HR review complete'));\nreturn [{ json: {\n  workflow: 'WF-HR', department: 'hr',\n  request_id: inp.request_id, workflow_source: inp.workflow_source, mode: inp.mode,\n  timestamp: new Date().toISOString(),\n  decision_status: decision_status, reason: reason,\n  next_workflow: needs_crea ? cfg.crea_workflow_id : null,\n  next_action: needs_crea ? 'route_to_CREA_WF8' : 'none',\n  confidence: inp.confidence, risk_level: risk_level,\n  crea_status: needs_crea ? 'pending' : 'not_required',\n  founder_approval_status: founder_needed ? (inp.founder_available ? 'requested' : 'required') : 'not_required',\n  execution_result: (inp.mode === 'execute' && decision_status === 'approved') ? 'executed' : 'simulated',\n  payload: inp.payload_obj,\n  analysis: { orchestrator: chro, talent_insights: talent, culture_engagement: culture, policy_enforcement: policy, hiring_ops: hiring, performance_review: perf },\n  logs: ['WF-HR processed ' + inp.request_id, 'risk_level=' + risk_level + ', decision=' + decision_status, needs_crea ? 'CREA review required' : 'CREA not required']\n}}];"
      },
      "id": "eebcbee1-0a06-4fe3-a26f-8516a5522b5a",
      "name": "Final HR Decision",
