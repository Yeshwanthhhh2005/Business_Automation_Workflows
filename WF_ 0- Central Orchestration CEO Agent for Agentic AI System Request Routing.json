      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"intent_summary\": {\n      \"type\": \"string\",\n      \"description\": \"Overall summary of the user's whole request\"\n    },\n    \"mode\": {\n      \"type\": \"string\",\n      \"enum\": [\n        \"simulation\",\n        \"execute\"\n      ]\n    },\n    \"subtasks\": {\n      \"type\": \"array\",\n      \"description\": \"One entry per department involved. Split a multi-part request into separate subtasks.\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"intent_summary\": {\n            \"type\": \"string\",\n            \"description\": \"What THIS subtask asks the department to do\"\n          },\n          \"department\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"finance\",\n              \"operations\",\n              \"marketing\",\n              \"sales\",\n              \"rnd\",\n              \"cx\",\n              \"tech\",\n              \"infra\",\n              \"hr\",\n              \"strategy\"\n            ]\n          },\n          \"task_type\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"strategic\",\n              \"operational\",\n              \"financial\",\n              \"technical\",\n              \"compliance\"\n            ]\n          },\n          \"urgency\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"low\",\n              \"medium\",\n              \"high\"\n            ]\n          },\n          \"risk_level\": {\n            \"type\": \"string\",\n            \"enum\": [\n              \"low\",\n              \"medium\",\n              \"high\"\n            ]\n          },\n          \"confidence_score\": {\n            \"type\": \"number\",\n            \"minimum\": 0,\n            \"maximum\": 1\n          }\n        },\n        \"required\": [\n          \"intent_summary\",\n          \"department\",\n          \"task_type\",\n          \"urgency\",\n          \"risk_level\",\n          \"confidence_score\"\n        ]\n      }\n    }\n  },\n  \"required\": [\n    \"intent_summary\",\n    \"mode\",\n    \"subtasks\"\n  ]\n}"
      },
