      "parameters": {
        "jsCode": "const contract = $input.first().json;\n\n// This node only normalizes the input for CEO classification\n// The contract was already built in Contract Builder\nconst normalizedData = {\n  ...contract,\n  normalized_input: contract.raw_input?.body?.request || contract.raw_input?.request || JSON.stringify(contract.raw_input)\n};\n\nreturn [normalizedData];"
      },
      "id": "e34bb153-073a-4e0c-a5ef-7016e0fa95cb",
