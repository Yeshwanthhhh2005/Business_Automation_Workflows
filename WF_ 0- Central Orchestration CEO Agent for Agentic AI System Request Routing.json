    {
      "parameters": {
        "jsCode": "// Logging only (no authority). Append an audit log entry to EVERY subtask contract.\nreturn $input.all().map(item => {\n  const c = item.json;\n  const logEntry = { timestamp: new Date().toISOString(), workflow: \"WF-0\", action: \"received_and_forwarded\", details: \"Routed to WF-10 and department for evaluation\" };\n  const prev = (c.audit && Array.isArray(c.audit.logs)) ? c.audit.logs : [];\n  return { json: { ...c, audit: { ...(c.audit||{}), logs: [...prev, logEntry] } } };\n});",
        "mode": "runOnceForAllItems"
      },
