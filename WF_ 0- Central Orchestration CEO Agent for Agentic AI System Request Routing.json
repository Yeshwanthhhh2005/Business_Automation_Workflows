        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"intent_summary\": {\n      \"type\": \"string\",\n      \"description\": \"Summary of the user's intent\"\n    },\n    \"department\": {\n      \"type\": \"string\",\n      \"enum\": [\"finance\", \"operations\", \"marketing\", \"sales\", \"rnd\", \"cx\", \"tech\", \"infra\", \"hr\", \"strategy\"],\n      \"description\": \"Target department for the request\"\n    },\n    \"task_type\": {\n      \"type\": \"string\",\n      \"enum\": [\"strategic\", \"operational\", \"financial\", \"technical\", \"compliance\"],\n      \"description\": \"Type of task being requested\"\n    },\n    \"urgency\": {\n      \"type\": \"string\",\n      \"enum\": [\"low\", \"medium\", \"high\"],\n      \"description\": \"Urgency level of the request\"\n    },\n    \"risk_level\": {\n      \"type\": \"string\",\n      \"enum\": [\"low\", \"medium\", \"high\"],\n      \"description\": \"Risk level associated with the request\"\n    },\n    \"recommended_workflow\": {\n      \"type\": \"string\",\n      \"enum\": [\"WF-1\", \"WF-2\", \"WF-3\", \"WF-4\", \"WF-5\", \"WF-6\", \"WF-7\", \"WF-9\"],\n      \"description\": \"Recommended workflow to handle the request\"\n    },\n    \"mode\": {\n      \"type\": \"string\",\n      \"enum\": [\"simulation\", \"execute\"],\n      \"description\": \"Execution mode for the request\"\n    },\n    \"confidence_score\": {\n      \"type\": \"number\",\n      \"minimum\": 0,\n      \"maximum\": 1,\n      \"description\": \"Confidence score of the classification\"\n    }\n  },\n  \"required\": [\"intent_summary\", \"department\", \"task_type\", \"urgency\", \"risk_level\", \"recommended_workflow\", \"mode\", \"confidence_score\"]\n}"
      },
