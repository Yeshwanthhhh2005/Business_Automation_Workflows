    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const DEPT2WF = { finance:'rNv9DzGl7IFHotwO', operations:'tQ9crXF3P0NOlWDy', rnd:'wruDXEwcbxlP2D7x', marketing:'IYl2NVikGCyySSU2', sales:'fjiL4YeNQ7FN4Yn5', cx:'IQ2YHdJsjseOTWAL', tech:'buYXMmxB3EmybKBk', infra:'buYXMmxB3EmybKBk', hr:'flYawPgsikdzuAek', strategy:'crzJvTXgeYpSYXTI' };\nconst base = $('Contract Builder').first().json;\nconst ceo = ($('CEO Agent').first().json || {}).output || {};\nlet subs = Array.isArray(ceo.subtasks) && ceo.subtasks.length ? ceo.subtasks : null;\nif (!subs) subs = [{ intent_summary: ceo.intent_summary, department: ceo.department, task_type: ceo.task_type, urgency: ceo.urgency, risk_level: ceo.risk_level, confidence_score: ceo.confidence_score }];\nreturn subs.map((s, i) => ({ json: {\n  request_id: (base.request_id || 'req') + '_' + (s.department || ('t' + i)),\n  parent_request_id: base.request_id || null,\n  source_workflow: 'WF-0',\n  source_workflow_id: $workflow.id,\n  department: s.department,\n  target_workflow_id: DEPT2WF[s.department] || null,\n  task_type: s.task_type,\n  urgency: s.urgency,\n  intent_summary: s.intent_summary,\n  mode: ceo.mode || base.mode || 'simulation',\n  confidence: typeof s.confidence_score === 'number' ? s.confidence_score : 0.7,\n  risk_level: s.risk_level || base.risk_level || 'low',\n  founder_available: false,\n  crea_status: base.crea_status || 'pending',\n  crea_reason: null,\n  failure_count: 0,\n  decision_status: 'proposed',\n  audit: base.audit || { original_contract_hash: '', logs: [], approvals: [], overrides: [] },\n  payload: (base.raw_input && base.raw_input.body && base.raw_input.body.payload) || {},\n  timestamp: new Date().toISOString(),\n} }));"
      },
