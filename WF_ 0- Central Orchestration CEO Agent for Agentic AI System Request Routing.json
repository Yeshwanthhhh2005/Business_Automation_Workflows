    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst results = items.map(i => ({\n  request_id: i.json.request_id,\n  department: i.json.department,\n  decision_status: i.json.decision_status,\n  execution_allowed: i.json.execution_allowed,\n  reason: i.json.reason,\n  intent_summary: i.json.intent_summary,\n}));\nreturn [{ json: {\n  parent_request_id: items[0] ? items[0].json.parent_request_id : null,\n  subtask_count: results.length,\n  departments: results.map(r => r.department),\n  results,\n  mode: items[0] ? items[0].json.mode : null,\n  timestamp: new Date().toISOString(),\n} }];"
      },
